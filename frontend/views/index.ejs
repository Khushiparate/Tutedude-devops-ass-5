<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>Student Registration</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f4f8;
           display: flex; justify-content: center; padding: 40px 20px; }
    .container { background: #fff; border-radius: 12px;
                 box-shadow: 0 4px 20px rgba(0,0,0,0.1);
                 padding: 40px; width: 100%; max-width: 520px; }
    h1 { text-align: center; color: #2d3748; margin-bottom: 6px; }
    .sub { text-align: center; color: #718096; margin-bottom: 24px; font-size:.9rem; }
    label { display:block; margin-bottom:5px; font-weight:600;
            color:#4a5568; font-size:.9rem; }
    input, select, textarea { width:100%; padding:10px 14px;
      border:1.5px solid #cbd5e0; border-radius:8px; font-size:.95rem;
      margin-bottom:16px; }
    input:focus, select:focus, textarea:focus
      { outline:none; border-color:#4299e1; }
    textarea { resize:vertical; height:90px; }
    button { width:100%; padding:12px; background:#4299e1; color:#fff;
             border:none; border-radius:8px; font-size:1rem;
             font-weight:600; cursor:pointer; }
    button:hover { background:#3182ce; }
    .success { background:#f0fff4; border:1.5px solid #68d391;
               border-radius:8px; padding:18px; margin-bottom:20px; }
    .success h2 { color:#276749; margin-bottom:10px; }
    .success p  { color:#2f855a; margin-bottom:5px; }
    .error { background:#fff5f5; border:1.5px solid #fc8181;
             border-radius:8px; padding:14px; margin-bottom:20px;
             color:#c53030; font-weight:500; }
    .badges { display:flex; gap:8px; justify-content:center; margin-bottom:22px; }
    .badge { background:#ebf8ff; color:#2b6cb0; border-radius:20px;
             padding:3px 12px; font-size:.78rem; font-weight:600;
             border:1px solid #bee3f8; }
    .req { color:#e53e3e; }
  </style>
</head>
<body>
<div class="container">
  <h1>📋 Student Registration</h1>
  <p class="sub">Node.js + Express → Flask Backend</p>
  <div class="badges">
    <span class="badge">Node.js</span>
    <span class="badge">Express</span>
    <span class="badge">Flask</span>
    <span class="badge">Docker</span>
  </div>

  <% if (result && result.success) { %>
  <div class="success">
    <h2>✅ Submitted Successfully!</h2>
    <p><strong>Name:</strong> <%= result.data.name %></p>
    <p><strong>Email:</strong> <%= result.data.email %></p>
    <p><strong>Student ID:</strong> <%= result.data.student_id %></p>
    <p><strong>Course:</strong> <%= result.data.course %></p>
    <% if (result.data.message) { %>
    <p><strong>Message:</strong> <%= result.data.message %></p>
    <% } %>
  </div>
  <% } %>

  <% if (error) { %>
  <div class="error">⚠️ <%= error %></div>
  <% } %>

  <form action="/submit" method="POST">
    <label>Full Name <span class="req">*</span></label>
    <input type="text" name="name" placeholder="e.g. John Doe" required/>

    <label>Email <span class="req">*</span></label>
    <input type="email" name="email" placeholder="e.g. john@example.com" required/>

    <label>Student ID <span class="req">*</span></label>
    <input type="text" name="student_id" placeholder="e.g. STU-2024-001" required/>

    <label>Course <span class="req">*</span></label>
    <select name="course" required>
      <option value="">-- Select a Course --</option>
      <option>Computer Science</option>
      <option>Software Engineering</option>
      <option>Data Science</option>
      <option>Information Technology</option>
      <option>Cybersecurity</option>
    </select>

    <label>Message (Optional)</label>
    <textarea name="message" placeholder="Any notes..."></textarea>

    <button type="submit">Submit →</button>
  </form>
</div>
</body>
</html>
